# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local database
local.db

# playwright mcp runtime logs
.playwright-mcp/

# claude code local settings (personal, not project-level)
.claude/settings.json

# large binary asset pack — ignore all, keep only files used in the app
public/assets/ui-pack/*
!public/assets/ui-pack/Individual files/
public/assets/ui-pack/Individual files/*
!public/assets/ui-pack/Individual files/3x/
public/assets/ui-pack/Individual files/3x/*
!public/assets/ui-pack/Individual files/3x/Checkboxes/
!public/assets/ui-pack/Individual files/3x/Buttons/
public/assets/ui-pack/Individual files/3x/Checkboxes/*
!public/assets/ui-pack/Individual files/3x/Checkboxes/Checkbox_01A_On.png
!public/assets/ui-pack/Individual files/3x/Checkboxes/Checkbox_01A_Off.png
public/assets/ui-pack/Individual files/3x/Buttons/*
!public/assets/ui-pack/Individual files/3x/Buttons/Button_05A_Normal.png
!public/assets/ui-pack/Individual files/3x/Buttons/Button_06A_Normal.png

# test screenshots
test-*.png
